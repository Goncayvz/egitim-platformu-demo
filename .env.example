BREVO_API_KEY=your_brevo_api_key
MAIL_FROM=your_verified_sender@example.com
MAIL_FROM_NAME=Eğitim Platformu

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=edu_platform_demo
DB_USER=root
DB_PASS=your_db_password

# Static admin login (optional; enable only if you need it)
STATIC_ADMIN_ENABLED=false
STATIC_ADMIN_EMAIL=admin@example.com
STATIC_ADMIN_USERNAME=admin
STATIC_ADMIN_PASSWORD=change-me

# Payments (scaffold)
# Options: mock | paytr | iyzico | stripe
PAYMENT_PROVIDER=
# mock only: success | failed | cancelled
PAYMENT_MOCK_STATUS=success

# PayTR (example)
PAYTR_MERCHANT_ID=
PAYTR_MERCHANT_KEY=
PAYTR_MERCHANT_SALT=

# iyzico (example)
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com

# Stripe (example)
STRIPE_PUBLISHABLE_KEY=
