# Basic hardening for Apache (InfinityFree/cPanel compatible)
Options -Indexes

# Make index.html the default homepage for directory URLs (/)
DirectoryIndex index.html index.php

# Block hidden files/folders (except Let's Encrypt / .well-known)
<IfModule mod_rewrite.c>
  RewriteEngine On

  # Redirect legacy homepage filename
  RewriteRule ^ansayfa\.html$ index.html [R=301,L]

  RewriteRule "(^|/)\\.(?!well-known/)" - [F,L]

  # Block private runtime storage (contains admin-saved settings/secrets)
  RewriteRule ^api/storage/ - [F,L]

  # Block direct access to internal include files
  RewriteRule ^api/_.*\\.php$ - [F,L]
  RewriteRule ^api/(?:db|config)\\.php$ - [F,L]
</IfModule>

# Deny access to sensitive files (secrets, backups, configs)
<FilesMatch "(?i)(^\\.env|schema\\.sql$|\\.sql$|\\.log$|composer\\.(json|lock)$|package(-lock)?\\.json$|\\.bak$|\\.old$|\\.orig$|\\.swp$|\\.tmp$)">
  Require all denied
</FilesMatch>

# Extra: deny access to common VCS/metadata folders if they exist
<IfModule mod_rewrite.c>
  RewriteRule "(^|/)(\\.git|\\.svn|\\.hg)(/|$)" - [F,L]
</IfModule>

# Security headers (wrapped to avoid 500 if module disabled)
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Cross-Origin-Opener-Policy "same-origin"
  Header always set Cross-Origin-Resource-Policy "same-origin"
</IfModule>

# Development convenience (Laragon/localhost): disable caching so old UI isn't shown after updates.
<IfModule mod_setenvif.c>
  SetEnvIfNoCase Host "^(localhost|127\\.0\\.0\\.1)$" AA_NO_CACHE=1
</IfModule>

<IfModule mod_headers.c>
  <FilesMatch "\\.(?:html|js|css)$">
    Header set Cache-Control "no-store, no-cache, must-revalidate, max-age=0" env=AA_NO_CACHE
    Header set Pragma "no-cache" env=AA_NO_CACHE
    Header set Expires "0" env=AA_NO_CACHE
  </FilesMatch>
</IfModule>

# Default caching policy (prod): HTML/PHP no-cache, static assets cached.
<IfModule mod_headers.c>
  <FilesMatch "\\.(?:html)$">
    Header set Cache-Control "no-store, must-revalidate, max-age=0"
  </FilesMatch>
  <FilesMatch "\\.(?:php)$">
    Header set Cache-Control "no-store, must-revalidate, max-age=0"
  </FilesMatch>
  <FilesMatch "\\.(?:css|js|mjs|png|jpg|jpeg|webp|gif|svg|ico|woff2?|ttf|eot)$">
    Header set Cache-Control "public, max-age=31536000, immutable" env=!AA_NO_CACHE
  </FilesMatch>
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType application/x-javascript "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
  ExpiresByType application/font-woff2 "access plus 1 year"
</IfModule>
